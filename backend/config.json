{
  "rag_mode": false,
  "llm": {
    "provider": "dashscope",
    "model": "qwen3.5-plus",
    "base_url": "https://dashscope.aliyuncs.com/compatible-mode/v1",
    "api_key": "",
    "temperature": 0.7,
    "max_tokens": 4096,
    "context_window": 131072
  },
  "embedding": {
    "provider": "dashscope",
    "model": "text-embedding-v4",
    "base_url": "https://dashscope.aliyuncs.com/compatible-mode/v1",
    "api_key": ""
  },
  "rag": {
    "top_k": 3,
    "similarity_threshold": 0.7
  },
  "compression": {
    "ratio": 0.5
  },
  "summary_model": {
    "model": "qwen-turbo",
    "temperature": 0
  },
  "middleware": {
    "tool_output_budget": {
      "enabled": true,
      "safe_ratio": 0.25,
      "pressure_ratio": 0.45,
      "budgets": {
        "terminal": 2000,
        "python_repl": 1500,
        "fetch_url": 3000,
        "read_file": 2000,
        "search_knowledge": 1000
      }
    },
    "summarization": {
      "enabled": true,
      "trigger_tokens": 8000,
      "keep_messages": 10
    },
    "tool_filter": {
      "enabled": true
    },
    "tool_call_limit": {
      "enabled": true,
      "limits": {
        "terminal": 10,
        "python_repl": 5
      }
    }
  },
  "features": {
    "task_state": true,
    "unified_memory": true
  },
  "auxiliary_model": {
    "model": "qwen3.5-flash",
    "temperature": 0
  },
  "hitl": {
    "enabled": true,
    "approval_required": [
      "terminal",
      "write_file",
      "python_repl"
    ],
    "timeout_seconds": 30,
    "timeout_action": "reject"
  },
  "mem0": {
    "enabled": true,
    "mode": "legacy",
    "auto_extract": true,
    "user_id": "default",
    "buffer_size": 5,
    "flush_interval_seconds": 300,
    "consolidation_interval_hours": 24,
    "consolidation_threshold": 50,
    "stale_threshold_days": 7,
    "expire_threshold_days": 30,
    "min_confidence": 0.3,
    "extraction_model": {}
  }
}